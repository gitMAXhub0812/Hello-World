# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=reviewguard
POSTGRES_USER=reviewguard
POSTGRES_PASSWORD=change_me_in_production

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose: anthropic | openai
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Email Notifications ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_FROM=noreply@reviewguard.local

# ── Frontend API URLs (accessible from browser) ───────────────────────────────
NEXT_PUBLIC_API_INGESTION_URL=http://localhost:8001
NEXT_PUBLIC_API_MODERATION_URL=http://localhost:8002
NEXT_PUBLIC_API_NOTIFICATION_URL=http://localhost:8003
NEXT_PUBLIC_API_REPORTING_URL=http://localhost:8004

# ── Risk Threshold ────────────────────────────────────────────────────────────
# Reviews with risk_score above this value trigger notifications (0.0 - 1.0)
DEFAULT_RISK_THRESHOLD=0.65
